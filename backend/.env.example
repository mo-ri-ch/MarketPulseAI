DATABASE_URL=postgresql://user:password@localhost:5432/marketpulse
SECRET_KEY=generate_a_secure_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
GEMINI_API_KEY=your_gemini_api_key_here

# SMTP Settings for Email Alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=marketpulse-alerts@marketpulse.com

# WhatsApp Cloud API (Meta) — for automatic breaking news alerts
# Setup: https://developers.facebook.com/ → Create App → Business → Add WhatsApp product
# Free test tier: send to up to 5 manually-verified numbers
WHATSAPP_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here
WHATSAPP_API_VERSION=v19.0
